        "z": "b76725b2126b6a64",
        "name": "function B",
        "func": "const fill = msg.status.fill;\nconst texto = (msg.status.text || \"\").toLowerCase();\n\nif (fill === \"red\" || texto.includes(\"disconnect\")) {\n    msg.payload = \"🔴 DESCONECTADO\";\n} else if (fill === \"yellow\") {\n    msg.payload = \"🟡 Reconectando...\";\n} else if (fill === \"green\") {\n    msg.payload = \"🟢 Conectado\";\n} else {\n    return null;\n}\n\nmsg.topic = \"mongo_status\";\nreturn msg;",
