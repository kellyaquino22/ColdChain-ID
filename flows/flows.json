    {
        "id": "8e995fcf4267db26",
        "type": "function",
        "z": "b76725b2126b6a64",
        "name": "function 1",
        "func": "// 1. Recupera a lista ou cria uma nova\nvar listaTags = context.get('listaTags') || [];\n\n// 2. Organiza o objeto exatamente com as chaves que a tabela vai ler\n// Note que usamos nomes simples sem espaços para evitar erros\nvar novaLeitura = {\n    \"id\": msg.payload.id,\n    \"setor\": msg.payload.setor,\n    \"horario\": msg.payload.data_hora\n};\n\n// 3. Adiciona no topo\nlistaTags.unshift(novaLeitura);\n\n// 4. Limita a 10 itens\nif (listaTags.length > 10) {\n    listaTags.pop();\n}\n\n// 5. Salva no contexto\ncontext.set('listaTags', listaTags);\n\n// 6. Envia para a tabela\nmsg.payload = listaTags;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
