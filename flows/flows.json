    {
        "id": "88c409ccf2acb541",
        "type": "function",
        "z": "b76725b2126b6a64",
        "name": "function 3",
        "func": "// Envia tabela salva ao iniciar (se existir)\nlet tabelaInicial = context.get('tabela') || [];\nif (tabelaInicial.length > 0) {\n    node.send({ payload: tabelaInicial });\n}\n\n// Recupera o storage do contexto do nó\nlet storage = context.get('storage') || {};\n\n// Suporte a array (vindo do MongoDB) ou objeto simples (vindo direto do MQTT)\nlet dados = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\n\n// Proteção\nif (!dados || !dados.data_hora || !dados.id || !dados.setor) {\n    return null;\n}\n\nconst id = dados.id;\nconst setorAtual = dados.setor;\nconst dataString = String(dados.data_hora).replace(\" \", \"T\");\nconst timestampAtual = new Date(dataString).getTime();\n\nif (isNaN(timestampAtual)) {\n    node.error(\"Falha ao processar data: \" + dados.data_hora);\n    return null;\n}\n\nif (!storage[id]) {\n    // Primeira leitura dessa tag — armazena e aguarda a próxima\n    storage[id] = { setor: setorAtual, timestamp: timestampAtual };\n    context.set('storage', storage);\n    return null;\n}\n\nconst registroAnterior = storage[id];\n\nif (registroAnterior.setor === setorAtual) {\n    // Mesma tag no mesmo setor — apenas atualiza o timestamp\n    storage[id].timestamp = timestampAtual;\n    context.set('storage', storage);\n    return null;\n}\n\n// Tag mudou de setor — calcula o tempo de permanência\nconst diffMs = Math.abs(timestampAtual - registroAnterior.timestamp);\nconst diffSegundos = Math.floor(diffMs / 1000);\nconst diffMinutos = (diffMs / (1000 * 60)).toFixed(2);\n\n// Recupera histórico da tabela\nlet tabela = context.get('tabela') || [];\n\n// Adiciona nova linha no topo\ntabela.unshift({\n    \"ID\": id,\n    \"De\": registroAnterior.setor,\n    \"Para\": setorAtual,\n    \"Segundos\": diffSegundos,\n    \"Minutos\": parseFloat(diffMinutos)\n});\n\n// Mantém apenas as últimas 20 linhas\nif (tabela.length > 20) tabela = tabela.slice(0, 20);\n\ncontext.set('tabela', tabela);\n\nmsg.payload = tabela;\n\n// Atualiza o storage com o setor atual\nstorage[id] = { setor: setorAtual, timestamp: timestampAtual };\ncontext.set('storage', storage);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "context.set('storage', {});",
        "finalize": "",
        "libs": [],
        "x": 900,
        "y": 200,
        "wires": [
            [
                "f24b41776a5553b8",
                "d2588f12db4accfb"
            ]
        ]
    },
    {
        "id": "8d742e5ee327178a",
        "type": "function",
        "z": "b76725b2126b6a64",
        "name": "function 4",
        "func": "// 1. Recupera o mapa de setores da memória (contexto)\nlet mapaSetores = context.get('mapaSetores') || {};\n\n// 2. Extrai os dados que vieram do HiveMQ\nconst id = msg.payload.id;\nconst setorAtual = msg.payload.setor;\n\n// 3. Atualiza a posição do ID no mapa (se houver dados válidos)\nif (id && setorAtual) {\n    mapaSetores[id] = setorAtual;\n}\n\n// 4. Salva o mapa atualizado de volta no contexto\ncontext.set('mapaSetores', mapaSetores);\n\n// 5. Inicializa os contadores\nlet contagem = {\n    \"Produção\": 0,\n    \"Câmara Fria\": 0,\n    \"Expedição\": 0\n};\n\n// 6. Conta quantos itens existem em cada setor\nObject.values(mapaSetores).forEach(setor => {\n    if (contagem.hasOwnProperty(setor)) {\n        contagem[setor]++;\n    }\n});\n\n// 7. Novo formato para o Dashboard 2.0 (chart)\nmsg.payload = [\n    { x: \"Produção\", y: contagem[\"Produção\"] },\n    { x: \"Câmara Fria\", y: contagem[\"Câmara Fria\"] },\n    { x: \"Expedição\", y: contagem[\"Expedição\"] }\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "context.set('mapaSetores', {});",
        "finalize": "",
        "libs": [],
