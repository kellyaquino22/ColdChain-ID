    {
        "id": "9a5bf5be4576bd6b",
        "type": "function",
        "z": "57b23ef35d371ade",
        "name": "Descriptografar AES",
        "func": "\nconst chave = Buffer.from('minhasenha123456', 'utf8');\nconst iv    = Buffer.from('1234567890123456', 'utf8');\n\ntry {\n    const dadosCriptografados = Buffer.from(msg.payload.toString().trim(), 'base64');\n\n    const decipher = crypto.createDecipheriv('aes-128-cbc', chave, iv);\n    decipher.setAutoPadding(true);\n\n    let jsonString = decipher.update(dadosCriptografados, null, 'utf8');\n    jsonString += decipher.final('utf8');\n\n    if (!jsonString || jsonString.length === 0) {\n        node.error('Descriptografia falhou: resultado vazio.');\n        return null;\n    }\n\n    node.warn('Descriptografado com sucesso: ' + jsonString);\n    msg.payload = jsonString;\n    return msg;\n\n} catch(e) {\n    node.error('Erro AES: ' + e.message);\n    return null;\n}\n",
