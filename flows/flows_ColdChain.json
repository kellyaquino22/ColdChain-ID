    {
        "id": "40aa4ebb533bac4d",
        "type": "function",
        "z": "57b23ef35d371ade",
        "name": "function 2",
        "func": "// Prepara a busca para o MongoDB encontrar a entrada na Produção\nmsg.payload = {\n    \"id\": msg.payload.id,\n    \"setor\": \"Produção\"\n};\nreturn msg;",
