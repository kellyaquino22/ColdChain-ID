    {
        "id": "fn_set_timeout",
        "type": "function",
        "z": "tab_gargalo",
        "name": "Salvar timeout no contexto do fluxo",
        "func": "// -------------------------------------------------------\n// CONFIGURAÇÃO DO TIMEOUT\n// Altere o valor 'payload' no nó inject acima para mudar\n// o número de horas antes do alerta disparar.\n// Padrão: 2 horas.\n// -------------------------------------------------------\n\nvar horas = Number(msg.payload);\nif (!horas || horas <= 0) horas = 2;\n\nflow.set('GARGALO_TIMEOUT_HORAS', horas);\nnode.log('Gargalo | Timeout configurado: ' + horas + 'h');\n\nreturn null;",
