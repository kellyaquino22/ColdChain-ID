    {
        "id": "fn_registrar_camara",
        "type": "function",
        "z": "tab_gargalo",
        "name": "Registrar entrada na Câmara Fria",
        "func": "// -------------------------------------------------------\n// ALERTA DE GARGALO — Passo 1: Registrar leitura na Câmara Fria\n// Salva no contexto global o timestamp de cada tag lida.\n// Não altera nenhum fluxo existente.\n// -------------------------------------------------------\n\nvar tagId   = msg.payload.tagId   || msg.payload.id || msg.payload.tag_id;\nvar TIMEOUT_HORAS = flow.get('GARGALO_TIMEOUT_HORAS') || 2;\n\nif (!tagId) {\n    node.warn('Payload sem tagId recebido no tópico câmara-fria: ' + JSON.stringify(msg.payload));\n    return null;\n}\n\nvar registro = {\n    tagId:        tagId,\n    ts_camara:    Date.now(),\n    expedido:     false,\n    alerta_ativo: false,\n    timeout_ms:   TIMEOUT_HORAS * 3600 * 1000\n};\n\n// Armazena no contexto global indexado pelo tagId\nvar pendentes = global.get('gargalo_pendentes') || {};\npendentes[tagId] = registro;\nglobal.set('gargalo_pendentes', pendentes);\n\nnode.log('Gargalo | Câmara Fria registrada: ' + tagId);\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 100,
        "wires": [
            []
        ]
    },
    {
        "id": "fn_confirmar_expedicao",
        "type": "function",
        "z": "tab_gargalo",
        "name": "Confirmar chegada na Expedição",
        "func": "// -------------------------------------------------------\n// ALERTA DE GARGALO — Passo 2: Confirmar expedição da tag\n// Marca a tag como expedida para o verificador não gerar alerta.\n// Não altera nenhum fluxo existente.\n// -------------------------------------------------------\n\nvar tagId = msg.payload.tagId || msg.payload.id || msg.payload.tag_id;\n\nif (!tagId) {\n    node.warn('Payload sem tagId recebido no tópico expedição: ' + JSON.stringify(msg.payload));\n    return null;\n}\n\nvar pendentes = global.get('gargalo_pendentes') || {};\n\nif (pendentes[tagId]) {\n    pendentes[tagId].expedido     = true;\n    pendentes[tagId].alerta_ativo = false;\n    pendentes[tagId].ts_expedicao = Date.now();\n    global.set('gargalo_pendentes', pendentes);\n    node.log('Gargalo | Expedição confirmada, alerta cancelado: ' + tagId);\n} else {\n    node.warn('Gargalo | Tag expedida sem registro prévio na Câmara Fria: ' + tagId);\n}\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 200,
        "wires": [
            []
        ]
    },
    {
        "id": "inject_verificador",
        "type": "inject",
        "z": "tab_gargalo",
        "name": "Verificador periódico (a cada 10 min)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "120",
        "crontab": "",
        "once": true,
        "onceDelay": 10,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 170,
        "y": 340,
        "wires": [
