                "fn_verificar_gargalo"
            ]
        ]
    },
    {
        "id": "fn_verificar_gargalo",
        "type": "function",
        "z": "tab_gargalo",
        "name": "Verificar tags em gargalo",
        "func": "// -------------------------------------------------------\n// ALERTA DE GARGALO — Passo 3: Varrer pendentes e disparar alertas\n// Roda a cada 10 minutos (configurado no nó inject acima).\n// Não altera nenhum fluxo existente.\n// -------------------------------------------------------\n\nvar pendentes = global.get('gargalo_pendentes') || {};\nvar agora     = Date.now();\nvar alertas   = [];\n\nObject.keys(pendentes).forEach(function(tagId) {\n    var reg = pendentes[tagId];\n\n    // Ignorar tags já expedidas ou com alerta já em tela\n    if (reg.expedido) return;\n\n    var decorrido_ms = agora - reg.ts_camara;\n\n    if (decorrido_ms >= reg.timeout_ms) {\n        var horas_decorridas = (decorrido_ms / 3600000).toFixed(1);\n\n        alertas.push({\n            tagId:           tagId,\n            ts_camara:       new Date(reg.ts_camara).toLocaleString('pt-BR'),\n            horas_decorridas: horas_decorridas,\n            timeout_horas:   reg.timeout_ms / 3600000\n        });\n\n        // Marca como alerta ativo para evitar spam em cada ciclo\n        pendentes[tagId].alerta_ativo = true;\n    }\n});\n\nglobal.set('gargalo_pendentes', pendentes);\n\nif (alertas.length === 0) {\n    node.log('Gargalo | Verificação OK — nenhum gargalo detectado.');\n    return null;\n}\n\n// Envia cada alerta como mensagem separada\nvar msgs = alertas.map(function(a) {\n    return {\n        payload: a,\n        topic:   'coldchain/alerta/gargalo'\n    };\n});\n\nreturn [msgs];",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 340,
        "wires": [
            [
                "fn_formatar_alerta"
            ]
        ]
    },
    {
        "id": "fn_formatar_alerta",
        "type": "function",
        "z": "tab_gargalo",
        "name": "Formatar mensagem de alerta",
        "func": "// -------------------------------------------------------\n// ALERTA DE GARGALO — Formata o texto do alerta\n// Gera msg.payload para o Dashboard e msg.telegram para o bot.\n// -------------------------------------------------------\n\nvar a = msg.payload;\n\nvar texto = '⚠️ ALERTA DE GARGALO\\n'\n          + 'Tag ID : ' + a.tagId + '\\n'\n          + 'Câmara : ' + a.ts_camara + '\\n'\n          + 'Aguardando expedição há ' + a.horas_decorridas + 'h'\n          + ' (limite: ' + a.timeout_horas + 'h)\\n'\n          + 'Verifique se o lote foi esquecido na câmara fria.';\n\nmsg.payload         = texto;\nmsg.telegram        = { text: texto };\nmsg.dashboard_class = 'alerta-gargalo';\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 650,
        "y": 340,
        "wires": [
            [
                "ui_notificacao",
                "mqtt_alerta_out",
                "fn_log_gargalo",
                "5e0b9b97f1024214"
            ]
        ]
