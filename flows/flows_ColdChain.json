    {
        "id": "57f708cfb195cb47",
        "type": "function",
        "z": "57b23ef35d371ade",
        "name": "function 3",
        "func": "let tabela = context.get('tabela') || [];\nlet storage = context.get('storage') || {};\n\nlet dados = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\n\nif (!dados || !dados.data_hora || !dados.id || !dados.setor) return null;\n\nconst id = dados.id;\nconst setorAtual = dados.setor;\nconst dataString = String(dados.data_hora).replace(\" \", \"T\");\nconst timestampAtual = new Date(dataString).getTime();\n\nif (isNaN(timestampAtual)) {\n    node.error(\"Falha ao processar data: \" + dados.data_hora);\n    return null;\n}\n\nif (!storage[id]) {\n    // Primeira leitura desta tag\n    storage[id] = { setor: setorAtual, timestamp: timestampAtual };\n    tabela.unshift({\n        \"ID\": id,\n        \"Setor Atual\": setorAtual,\n        \"Tempo (s)\": 0,\n        \"Tempo (min)\": 0\n    });\n} else {\n    const anterior = storage[id];\n    const diffMs = Math.abs(timestampAtual - anterior.timestamp);\n    const diffSeg = Math.floor(diffMs / 1000);\n    const diffMin = parseFloat((diffMs / 60000).toFixed(2));\n\n    // Encontra linha existente na tabela\n    let idx = tabela.findIndex(row => row[\"ID\"] === id);\n\n    if (idx !== -1) {\n        tabela[idx][\"Setor Atual\"] = setorAtual;\n        tabela[idx][\"Tempo (s)\"] = diffSeg;\n        tabela[idx][\"Tempo (min)\"] = diffMin;\n    } else {\n        tabela.unshift({\n            \"ID\": id,\n            \"Setor Atual\": setorAtual,\n            \"Tempo (s)\": diffSeg,\n            \"Tempo (min)\": diffMin\n        });\n    }\n\n    // CRÍTICO: sempre atualiza o timestamp, independente de mudar setor ou não\n    storage[id] = { setor: setorAtual, timestamp: timestampAtual };\n}\n\nif (tabela.length > 20) tabela = tabela.slice(0, 20);\n\ncontext.set('tabela', tabela);\ncontext.set('storage', storage);\n\nmsg.payload = tabela;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "context.set('storage', {});",
        "finalize": "",
        "libs": [],
        "x": 900,
        "y": 200,
        "wires": [
            [
                "c291d80458d176fb",
                "cca86ec493ebabe2"
            ]
        ]
    },
    {
        "id": "99f38296b677bde6",
        "type": "function",
        "z": "57b23ef35d371ade",
        "name": "function 4",
        "func": "let mapaSetores = context.get('mapaSetores') || {};\nlet dados = msg.payload;\n\nmapaSetores[dados.id] = dados.setor;\ncontext.set('mapaSetores', mapaSetores);\n\nlet contagem = { \"Produção\": 0, \"Câmara Fria\": 0, \"Expedição\": 0 };\n\nObject.values(mapaSetores).forEach(s => {\n    if (contagem.hasOwnProperty(s)) contagem[s]++;\n});\n\n// Envia mensagens separadas para o gráfico de barras\nnode.send({ topic: \"Produção\", payload: contagem[\"Produção\"] });\nnode.send({ topic: \"Câmara Fria\", payload: contagem[\"Câmara Fria\"] });\nnode.send({ topic: \"Expedição\", payload: contagem[\"Expedição\"] });\n\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "context.set('mapaSetores', {});",
        "finalize": "",
